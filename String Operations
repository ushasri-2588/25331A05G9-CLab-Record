#include <stdio.h>
#include <string.h>
int main() 
{
    char s1[50], s2[50];
    printf("Enter first string: ");
    scanf("%s",s1);
    printf("Enter second string: ");
    scanf("%s",s2);
    printf("Copy: %s\n",strcpy(s1,s2));
    printf("Concatenate: %s\n",strcat(s1,s2));
    printf("Compare: %d\n",strcmp(s1,s2));
    printf("Length: %d\n",strlen(s1));
    return 0;
}
