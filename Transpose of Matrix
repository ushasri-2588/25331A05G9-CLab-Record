#include<stdio.h>
int main()
{
	int i,j,rows,columns,A[10][10],T[10][10];
	printf("Enter no.of Rows&Columns : ");
	scanf("%d%d",&rows,&columns);
	printf("Matrix is : ");
	for(i=0;i<rows;i++)
	{
	for(j=0;j<columns;j++)
	{
	scanf("%d",&A[i][j]);
	}
	}
	printf("Transpose is : ");
	for(i=0;i<rows;i++)
	{
	for(j=0;j<columns;j++)
	{
	T[j][i]=A[i][j];
	}
	}
	for(j=0;j<columns;j++)
	{
	for(i=0;i<rows;i++)
	{
	printf(" %d",T[j][i]);
	}
	printf("\n");
	}
	return 0;
}
